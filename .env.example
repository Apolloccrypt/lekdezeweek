# Kopieer naar .env.local voor lokaal ontwikkelen (NIET committen — zit in .gitignore)
# In Vercel: zet deze onder Project Settings → Environment Variables.

# ─── Upstash Redis ──────────────────────────────────────
# Worden AUTOMATISCH gezet als je Upstash via Vercel Marketplace koppelt.
# Hoef je dus niet handmatig in te vullen in Vercel; wel lokaal als je
# vercel dev draait (via `vercel env pull .env.local`).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Resend ─────────────────────────────────────────────
# Maak account op https://resend.com, haal API key uit dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ─── Afzender ──────────────────────────────────────────
# Zonder eigen domein (voor testen):   LekDezeWeek <onboarding@resend.dev>
# Met eigen domein (productie):        LekDezeWeek <radar@lekdezeweek.nl>
FROM_EMAIL=LekDezeWeek <onboarding@resend.dev>

# ─── Site ──────────────────────────────────────────────
# Gebruikt voor unsubscribe links in e-mails
SITE_URL=https://lekdezeweek.nl
